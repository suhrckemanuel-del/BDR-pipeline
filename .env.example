# Copy this file to .env and fill in your keys. .env is gitignored and never committed.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic — https://console.anthropic.com/settings/api-keys
# Used by every agent (enrichment, strategist, humanizer, critic).
ANTHROPIC_API_KEY=

# Exa — https://exa.ai/api
# Used by enrichment for live news + job-posting signals. Pipeline still runs
# without it (just fewer signals).
EXA_API_KEY=

# Hunter.io — https://hunter.io/api-documentation
# Used by enrichment for contact discovery on the prospect's domain. Pipeline
# still runs without it (sequence drops the named-contact personalization).
HUNTER_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Notion — https://www.notion.so/my-integrations
# Required only if you enable CRM sync (crm.enabled: true in tenant config.yaml).
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Gmail — required only if you use scripts/send_via_gmail.py to send queued sequences.
# Create an App Password at myaccount.google.com/apppasswords (requires 2FA).
GMAIL_SENDER=
GMAIL_APP_PASSWORD=

# ─── Tenant pinning ──────────────────────────────────────────────────────────

# Pin a tenant for Streamlit / scripted runs. When set, the sidebar dropdown
# is disabled. Leave empty to pick from the dropdown each time.
BDR_TENANT=

# ─── LangSmith tracing (optional) ────────────────────────────────────────────

# Uncomment to send traces to LangSmith. Useful for debugging multi-node runs.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=bdr-pipeline
